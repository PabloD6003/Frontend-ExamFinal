# URL the "Reportar fraude" CTAs redirect to.
# Leave as the default to use the internal "/reportar-estafa" route in this app
# (currently a "Proyecto en construcción" placeholder).
# When the public reports platform is ready, point this to its production URL,
# e.g. http://localhost:5174/reportar-estafa or https://reportes.labcibe.una.ac.cr/reportar-estafa
VITE_REPORTS_URL=/reportar-estafa

# URL base del Backend (.NET) para el módulo de reporte de fraudes.
# En local: el puerto donde corre su API (ej. http://localhost:5000).
# En producción: la URL pública del API en Monster ASP.NET.
VITE_API_URL=http://localhost:5000
